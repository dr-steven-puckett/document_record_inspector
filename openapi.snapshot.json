  "info": {
    "title": "document_record_inspector",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/tools/document_record_inspector/documents/{document_id}": {
      "get": {
        "description": "Return the full record view for one document.\n\nAggregates: documents row, document_files, chunks, embeddings, summaries,\nand ingest_runs for the given document_id.",
        "operationId": "document_record_inspector_inspect",
        "parameters": [
          {
            "in": "path",
            "name": "document_id",
            "required": true,
            "schema": {
              "title": "Document Id",
              "type": "string"
            }
          },
          {
            "description": "Include chunk text in response",
            "in": "query",
            "name": "include_text",
            "required": false,
            "schema": {
              "default": false,
              "description": "Include chunk text in response",
              "title": "Include Text",
              "type": "boolean"
            }
          },
          {
            "description": "Include embedding vectors in response",
            "in": "query",
            "name": "include_vectors",
            "required": false,
            "schema": {
              "default": false,
              "description": "Include embedding vectors in response",
              "title": "Include Vectors",
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InspectionResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "description": "Document not found"
          },
          "422": {
            "description": "Validation error"
          }
        },
        "summary": "Document Record Inspector Inspect",
        "tags": [
          "tools:document_record_inspector"
        ]
      }
    },
    "/v1/tools/document_record_inspector/health": {
      "get": {
        "description": "Return tool health status.",
        "operationId": "document_record_inspector_health",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Document Record Inspector Health",
        "tags": [
          "tools:document_record_inspector"
        ]
      }
    }
  }
